# ===== REQUIRED =====

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3080

# Upstash Redis (rate limiting + PIN lock)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== EMAIL (Resend) =====
# Get from https://resend.com/api-keys
# One key handles both auth emails and digest emails
RESEND_API_KEY=re_xxxxxxxxxxxx
# From address (must be verified domain in Resend, or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=Ostracon <noreply@ostracon.app>

# ===== SUPABASE ADMIN =====
# Service role key from your self-hosted Supabase (Settings → API)
# Required for generating magic links server-side
SUPABASE_SERVICE_ROLE_KEY=

# ===== PAYMENTS (Stripe) =====
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ===== IMAGE MODERATION (Sightengine) =====
# Get from https://sightengine.com/dashboard
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# ===== PUSH NOTIFICATIONS =====
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=support@ostracon.app

# ===== CRON PROTECTION =====
# Random secret to protect cron endpoints
CRON_SECRET=

# ===== OPTIONAL =====

# GIF picker (Tenor API, works without key using default)
NEXT_PUBLIC_TENOR_API_KEY=

# reCAPTCHA
NEXT_PUBLIC_GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=
