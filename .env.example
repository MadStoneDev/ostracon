# ===== REQUIRED =====

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3080

# Supabase Admin (service role key for magic link generation)
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (rate limiting + PIN lock)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== EMAIL (Resend) =====
# Get from https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Ostracon <noreply@ostracon.app>

# ===== STORAGE (Cloudflare R2) =====
# Buckets: ostracon-avatars, ostracon-images
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-domain.com

# ===== BOT PROTECTION (Cloudflare Turnstile) =====
# Get from https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ===== PAYMENTS (Stripe) =====
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== IMAGE MODERATION (Sightengine) =====
# Get from https://sightengine.com/dashboard
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# ===== PUSH NOTIFICATIONS =====
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=support@ostracon.app

# ===== CRON PROTECTION =====
CRON_SECRET=

# ===== GIF (Giphy) =====
# Get from https://developers.giphy.com/dashboard/
NEXT_PUBLIC_GIPHY_API_KEY=
